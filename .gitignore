# ============================================================
#   .gitignore for Blazor Web App / .NET Project
#   Excludes everything unnecessary for GitHub publishing
# ============================================================


# -------------------------------s----------------
# Visual Studio & IDE Files
# -----------------------------------------------
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates
*.pidb
*.userprefs
.idea/
*.ncb
*.sdf
*.opensdf
*.VC.db
*.VC.VC.opendb


# -----------------------------------------------
# Build Output
# -----------------------------------------------
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
build/
publish/
artifacts/


# -----------------------------------------------
# .NET / MSBuild
# -----------------------------------------------
project.lock.json
project.fragment.lock.json
artifacts/
**/Properties/launchSettings.json
*.binlog
*.msbuildcache


# -----------------------------------------------
# NuGet Packages
# -----------------------------------------------
*.nupkg
*.snupkg
packages/
!**/packages/repositories.config
*.nuget.props
*.nuget.targets
nuget.config.local


# -----------------------------------------------
# Blazor / WebAssembly Specific
# -----------------------------------------------
wwwroot/_framework/
wwwroot/appsettings.*.json
!wwwroot/appsettings.json


# -----------------------------------------------
# ASP.NET Core
# -----------------------------------------------
**/appsettings.Development.json
**/appsettings.Local.json
**/appsettings.Staging.json
**/appsettings.Production.json


# -----------------------------------------------
# Secrets & Sensitive Files
# -----------------------------------------------
secrets.json
**/secrets.json
*.pfx
*.p12
*.key
*.pem
*.crt
*.cer
.env
.env.*
!.env.example


# -----------------------------------------------
# Test Results & Coverage
# -----------------------------------------------
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResults/
coverage/
*.trx
*.coverage
*.coveragexml
*.opencover.xml
*.cobertura.xml


# -----------------------------------------------
# Publish Profiles (contain server-specific info)
# -----------------------------------------------
**/Properties/PublishProfiles/
*.pubxml
*.pubxml.user


# -----------------------------------------------
# Entity Framework / Database
# -----------------------------------------------
*.mdf
*.ldf
*.ndf
*.db
*.sqlite
*.sqlite3


# -----------------------------------------------
# Node / Frontend Tooling (if used with Blazor)
# -----------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/
dist/
.pnp.*


# -----------------------------------------------
# OS Generated Files
# -----------------------------------------------

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns

# Linux
*~
.nfs*


# -----------------------------------------------
# Rider / JetBrains IDE
# -----------------------------------------------
.idea/
*.sln.iml


# -----------------------------------------------
# Resharper
# -----------------------------------------------
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user


# -----------------------------------------------
# Temp / Cache Files
# -----------------------------------------------
*.tmp
*.temp
*.cache
*.bak
*.swp
*.orig
*_i.c
*_p.c
*.ilk
*.pdb
*.iobj
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tlh
*.tli
*.tlog
*.manifest
*.spec
ipch/
AutoTest.Net/


# -----------------------------------------------
# Docker (local overrides only)
# -----------------------------------------------
docker-compose.override.yml
.dockerignore.local


# -----------------------------------------------
# Generated Static Files (CI/CD rebuilds these)
# -----------------------------------------------
**/wwwroot/css/site.min.css
**/wwwroot/js/site.min.js
bundleconfig.json.bak