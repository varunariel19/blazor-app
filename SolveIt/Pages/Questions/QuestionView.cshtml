@page "/Question/{questionId:guid}"
@model SolveIt.Pages.Questions.QuestionViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = Model.Question.Title;
    var q = Model.Question;
    var isLoggedIn = Model.IsLoggedIn;
    var currentUser = q.User;
    var avatarInitial = isLoggedIn && currentUser != null
                            ? (currentUser.DisplayName?.Substring(0, 1) ?? "?").ToUpper()
                            : "?";


}

<link rel="stylesheet" href="~/css/QuestionView.css" asp-append-version="true" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet" />
<script src="/js/script.js" defer></script>

<div class="qv-bg-noise"></div>

<div class="qv-shell">

    <aside class="qv-sidebar">
        <div class="qv-sidebar-sticky">
            <div class="qv-vote-block">
                <button class="qv-upvote @(isLoggedIn ? "" : "qv-upvote--locked")"
                        id="upvote-btn"
                        data-id="@q.QuestionId"
                        onclick="handleVote(this)"
                    @(isLoggedIn ? "" : "disabled title=\"Log in to vote\"")>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15" /></svg>
                </button>
                <span class="qv-vote-num" id="vote-count-@q.QuestionId">@q.VoteCount</span>
                <span class="qv-vote-label">votes</span>
            </div>

            <div class="qv-stat-list">
                <div class="qv-stat-pill" title="Views">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                    <span>@q.ViewCount</span>
                </div>
                <div class="qv-stat-pill" title="Comments">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                    <span id="sidebar-comment-count">@q.CommentCount</span>
                </div>
                <div class="qv-stat-pill" title="Answers">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
                    <span>@q.SolutionCount</span>
                </div>
            </div>

            <nav class="qv-jump-nav">
                <a href="#question-body" class="qv-jump">Question</a>
                <a href="#solutions-panel" class="qv-jump" onclick="openSolutions(); return true;">Answers</a>
                <a href="#add-solution" class="qv-jump">Add Answer</a>
                <a href="#comments-panel" class="qv-jump">Comments</a>
            </nav>
        </div>
    </aside>

    <main class="qv-main">

                @if (!string.IsNullOrEmpty(q.CoverImageUrl))
                {
            <div class="qv-cover">
                <img src="@q.CoverImageUrl" alt="cover" />
                <div class="qv-cover-fade"></div>
            </div>
                }

        <article class="qv-question-card" id="question-body">

                        @if (q.QuestionTags.Any())
                        {
                <div class="qv-tags">
                                @foreach (var tag in q.QuestionTags)
                                {
                        <span class="qv-tag" style="--tag-color:@tag.ColorHex">@tag.TagName</span>
                                }
                </div>
                        }

            <h1 class="qv-title">@q.Title</h1>

            <div class="qv-author-row">
                <div class="qv-avatar" style="--av-color:@StringToColor(q.User.DisplayName ?? q.User.UserName ?? "U")">
                                @((q.User.DisplayName ?? q.User.UserName ?? "?").Substring(0, 1).ToUpper())
                </div>
                <div class="qv-author-info">
                    <span class="qv-author-name">@(q.User.DisplayName ?? q.User.UserName)</span>
                    <span class="qv-author-date">Asked @TimeAgo(q.CreatedAt)</span>
                </div>
                            @if (q.UpdatedAt.HasValue)
                            {
                    <span class="qv-edited-badge">edited @TimeAgo(q.UpdatedAt.Value)</span>
                            }
            </div>

            <div class="qv-body-content">@Html.Raw(q.Body)</div>

        </article>

        <section id="solutions-panel">
            <div class="qv-section-header">
                <h2 class="qv-section-title">
                    <span class="qv-section-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12" /></svg>
                    </span>
                    <span id="sol-heading">@q.SolutionCount Answer@(q.SolutionCount != 1 ? "s" : "")</span>
                </h2>
                <button class="qv-reveal-btn" onclick="toggleSolutions()">
                    <span id="reveal-label">Show Answers</span>
                    <svg id="reveal-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg>
                </button>
            </div>

            <div class="qv-solutions-body" id="solutions-body" style="display:none;">
                                @if (q.Solutions.Any())
                                {
                                    @foreach (var sol in q.Solutions.OrderByDescending(s => s.Votes))
                                    {
                        <article class="qv-sol-card" id="solution-@sol.SolId">
                            <div class="qv-sol-vote-col">
                                <button class="qv-sol-like @(isLoggedIn ? "" : "qv-upvote--locked")"
                                        data-id="@sol.SolId" data-action="like"
                                        onclick="handleSolVote(this)"
                                                @(isLoggedIn ? "" : "disabled")>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z" /><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3" /></svg>
                                    <span id="like-@sol.SolId">@sol.Likes</span>
                                </button>
                                <span class="qv-sol-netvotes" id="netvotes-@sol.SolId">@sol.Votes</span>
                                <button class="qv-sol-dislike @(isLoggedIn ? "" : "qv-upvote--locked")"
                                        data-id="@sol.SolId" data-action="dislike"
                                        onclick="handleSolVote(this)"
                                                @(isLoggedIn ? "" : "disabled")>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z" /><path d="M17 2h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17" /></svg>
                                    <span id="dislike-@sol.SolId">@sol.Dislikes</span>
                                </button>
                            </div>
                            <div class="qv-sol-content">
                                <div class="qv-sol-meta">
                                    <div class="qv-avatar qv-avatar--sm" style="--av-color:@StringToColor(sol.User.DisplayName ?? sol.User.UserName ?? "U")">
                                                        @((sol.User.DisplayName ?? sol.User.UserName ?? "?").Substring(0, 1).ToUpper())
                                    </div>
                                    <span class="qv-author-name">@(sol.User.DisplayName ?? sol.User.UserName)</span>
                                    <span class="qv-author-date">@TimeAgo(sol.CreatedAt)</span>
                                                    @foreach (var t in sol.SolutionTags)
                                                    {
                                        <span class="qv-tag qv-tag--sm" style="--tag-color:@t.ColorHex">@t.TagName</span>
                                                    }
                                </div>
                                <div class="qv-body-content">@Html.Raw(sol.Body)</div>
                            </div>
                        </article>
                                    }
                                }
                                else
                                {
                    <div class="qv-empty-state">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                        <p>No answers yet — be the first!</p>
                    </div>
                                }
            </div>
        </section>

        <section id="add-solution" class="qv-add-solution">
            <div class="qv-section-header">
                <h2 class="qv-section-title">
                    <span class="qv-section-icon qv-section-icon--green">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    </span>
                    Your Answer
                </h2>
            </div>

                                @if (isLoggedIn)
                                {
                <div class="qv-editor-wrap">
                    <div class="qv-editor-toolbar">
                        <div class="qv-toolbar-group">
                            <button type="button" class="qv-tb-btn" onclick="fmtSol('bold')" title="Bold"><b>B</b></button>
                            <button type="button" class="qv-tb-btn" onclick="fmtSol('italic')" title="Italic"><i>I</i></button>
                            <button type="button" class="qv-tb-btn" onclick="fmtSol('underline')" title="Underline"><u>U</u></button>
                            <button type="button" class="qv-tb-btn" onclick="fmtSol('strikeThrough')" title="Strike"><s>S</s></button>
                        </div>
                        <div class="qv-toolbar-sep"></div>
                        <div class="qv-toolbar-group">
                            <button type="button" class="qv-tb-btn" onclick="fmtSol('insertUnorderedList')" title="Bullets">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6" /><line x1="8" y1="12" x2="21" y2="12" /><line x1="8" y1="18" x2="21" y2="18" /><line x1="3" y1="6" x2="3.01" y2="6" /><line x1="3" y1="12" x2="3.01" y2="12" /><line x1="3" y1="18" x2="3.01" y2="18" /></svg>
                            </button>
                            <button type="button" class="qv-tb-btn" onclick="fmtSol('insertOrderedList')" title="Numbers">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="10" y1="6" x2="21" y2="6" /><line x1="10" y1="12" x2="21" y2="12" /><line x1="10" y1="18" x2="21" y2="18" /><path d="M4 6h1v4" /><path d="M4 10h2" /><path d="M6 18H4c0-1 2-2 2-3s-1-1.5-2-1" /></svg>
                            </button>
                        </div>
                        <div class="qv-toolbar-sep"></div>
                        <div class="qv-toolbar-group">
                            <button type="button" class="qv-tb-btn" onclick="fmtHeading()" title="Heading">H</button>
                            <button type="button" class="qv-tb-btn" onclick="fmtBlockquote()" title="Quote">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z" /><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z" /></svg>
                            </button>
                            <button type="button" class="qv-tb-btn" onclick="fmtCode()" title="Code">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" /></svg>
                            </button>
                            <button type="button" class="qv-tb-btn" onclick="fmtLink()" title="Link">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" /><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" /></svg>
                            </button>
                        </div>
                    </div>

                    <div class="qv-editor"
                         id="sol-editor"
                         contenteditable="true"
                         data-placeholder="Write a clear, detailed answer…"
                         spellcheck="true"></div>

                    <div class="qv-editor-footer">
                        <span class="qv-editor-hint">Supports <b>bold</b>, <i>italic</i>, lists, code &amp; links</span>
                        <button class="qv-post-btn" id="post-sol-btn" onclick="submitSolution('@q.QuestionId')">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" /></svg>
                            Post Answer
                        </button>
                    </div>
                </div>
                                }
                                else
                                {
                <div class="qv-login-card">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" /><polyline points="10 17 15 12 10 7" /><line x1="15" y1="12" x2="3" y2="12" /></svg>
                    <div>
                        <strong>Want to answer?</strong>
                        <p><a href="/login" class="qv-link">Log in</a> or <a href="/register" class="qv-link">create an account</a>.</p>
                    </div>
                </div>
                                }
        </section>

        <section id="comments-panel" class="qv-comments-section">
            <div class="qv-section-header">
                <h2 class="qv-section-title">
                    <span class="qv-section-icon qv-section-icon--purple">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                    </span>
                    Comments <span class="qv-count-badge" id="comment-count-badge">@q.CommentCount</span>
                </h2>
            </div>

            <div class="qv-comment-list" id="comment-list">
                                        @if (!q.Comments.Any())
                                        {
                    <p class="qv-no-comments" id="no-comments-msg">No comments yet.</p>
                                        }
                                        @foreach (var c in q.Comments.OrderByDescending(c => c.CreatedAt))
                                        {
                    <div class="qv-comment" id="comment-@c.CommentId">
                        <div class="qv-avatar qv-avatar--xs" style="--av-color:@StringToColor(c.User.DisplayName ?? c.User.UserName ?? "U")">
                                                    @((c.User.DisplayName ?? c.User.UserName ?? "?").Substring(0, 1).ToUpper())
                        </div>
                        <div class="qv-comment-bubble">
                            <div class="qv-comment-header">
                                <span class="qv-comment-author">@(c.User.DisplayName ?? c.User.UserName)</span>
                                <span class="qv-comment-time">@TimeAgo(c.CreatedAt)</span>
                            </div>
                            <p class="qv-comment-text">@c.Body</p>
                        </div>
                    </div>
                                        }
            </div>

                                    @if (isLoggedIn)
                                    {
                <div class="qv-comment-form">
                    <div class="qv-avatar qv-avatar--sm" style="--av-color:@StringToColor(currentUser?.DisplayName ?? "U")">
                                                @avatarInitial
                    </div>
                    <div class="qv-comment-input-wrap">
                        <textarea id="comment-input"
                                  class="qv-comment-textarea"
                                  placeholder="Add a comment…"
                                  rows="2"
                                  maxlength="1000"
                                  oninput="updateCharCount(this)"></textarea>
                        <div class="qv-comment-actions">
                            <span class="qv-char-count" id="char-count">0 / 1000</span>
                            <button class="qv-comment-submit" onclick="submitComment('@q.QuestionId')">Comment</button>
                        </div>
                    </div>
                </div>
                                    }
                                    else
                                    {
                <div class="qv-login-inline"><a href="/login" class="qv-link">Log in</a> to comment.</div>
                                    }
        </section>

    </main>
</div>

<div class="qv-toast" id="qv-toast"><span id="qv-toast-msg"></span></div>

@functions {
    string TimeAgo(DateTime dt)
    {
        var d = DateTime.UtcNow - dt;
        if (d.TotalSeconds < 60) return "just now";
        if (d.TotalMinutes < 60) return $"{(int)d.TotalMinutes}m ago";
        if (d.TotalHours < 24) return $"{(int)d.TotalHours}h ago";
        if (d.TotalDays < 30) return $"{(int)d.TotalDays}d ago";
        if (d.TotalDays < 365) return $"{(int)(d.TotalDays / 30)}mo ago";
        return $"{(int)(d.TotalDays / 365)}y ago";
    }
    string StringToColor(string s)
    {
        int h = s.Aggregate(0, (a, c) => a * 31 + c);
        return $"hsl({Math.Abs(h) % 360},65%,55%)";
    }
}
