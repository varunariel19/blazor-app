@page "/saved"
@layout SolveIt.Components.Layout.MainLayout
@inject SolveIt.Services.QuestionService QuestionService
@inject SolveIt.Services.AuthService AuthService
@inject SolveIt.UI_state.UiStateService UiState
@using SolveIt.Models

<div class="saved-page">

    <div class="saved-header">
        <h1>Saved Questions</h1>
        <p>Questions you've bookmarked for later</p>
    </div>

    @if (IsLoading)
    {
        <div class="saved-state">
            <i class="fa-regular fa-hourglass-half"></i>
            <span>Loading saved questions…</span>
        </div>
    }
    else if (SavedQuestions.Count == 0)
    {
        <div class="saved-state">
            <i class="fa-regular fa-floppy-disk"></i>
            <span>You haven't saved any questions yet.</span>
        </div>
    }
    else
    {
        <div class="saved-count">@SavedQuestions.Count saved @(SavedQuestions.Count == 1 ? "question" : "questions")</div>

        <div class="saved-list">
            @foreach (var sq in SavedQuestions)
            {
                <div class="saved-card">
                    <div class="saved-card-main">
                        <a href="/questions/@sq.Question.QuestionId" class="saved-card-title">
                            @sq.Question.Title
                        </a>

                        <div class="saved-card-tags">
                            @foreach (var tag in sq.Question.QuestionTags ?? [])
                            {
                                <span class="tag">@tag.TagName</span>
                            }
                        </div>

                        <div class="saved-card-meta">
                            <span class="meta-item">
                                <i class="fa-regular fa-lightbulb"></i>
                                @sq.Question.SolutionCount @(sq.Question.SolutionCount == 1 ? "solution" : "solutions")
                            </span>
                            <span class="meta-item">
                                <i class="fa-regular fa-clock"></i>
                                Saved @TimeAgo(sq.SavedAt)
                            </span>
                        </div>
                    </div>

                    <div class="saved-card-actions">
                        @* <button class="unsave-btn" title="Remove from bookmarks" @onclick="() => HandleUnsave(sq.QuestionId)"> *@
                        @*     <i class="fa-solid fa-bookmark"></i> *@
                        @*     <span>Unsave</span> *@
                        @* </button> *@
                    </div>
                </div>
            }
        </div>
    }

</div>

@if (ToastVisible)
{
    <div class="toast @ToastCssClass">
        <i class="fa-solid @ToastIcon"></i>
        <span>@ToastMessage</span>
    </div>
}

@code {
    private List<Models.SavedQuestion> SavedQuestions = [];
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await HandleGetAllSavedQues();
    }

    private async Task HandleGetAllSavedQues()
    {
        IsLoading = true;

        try
        {
            string userId = String.Empty;

            if (UiState.UserData != null)
            {
                userId = UiState.UserData.Id;
            }
            else
            {
                var user = await AuthService.GetCurrentUserAsync();
                if (user != null)
                    userId = user.Id;
            }

            if (userId == String.Empty) return;

            var result = await QuestionService.GetSavedQuestionsAsync(userId);
            if(result != null)
            {
                SavedQuestions = result;
            }
        }
        catch (Exception ex)
        {
            ShowToast("Failed to load saved questions.", ToastType.Error);
        }
        finally
        {
            IsLoading = false;
        }
    }

