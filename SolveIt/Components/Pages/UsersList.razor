@page "/users"
@layout SolveIt.Components.Layout.MainLayout
@inject SolveIt.Services.AuthService authService
@inject SolveIt.UI_state.UiStateService UiState;

<h2 class="page-title">👥 Community Members</h2>

@if (Users == null || Users.Count == 0)
{
    <p class="empty-state">No users found.</p>
}
else
{
    <div class="users-grid">
        @foreach (var user in Users)
        {
            @if(user.Id != UiState.UserData!.Id)
            {
                <div class="user-card">

                    <div class="avatar">
                        <img src="@(!string.IsNullOrEmpty(user.AvatarUrl) ? user.AvatarUrl : "/images/default-avatar.png")" />
                    </div>

                    <div class="user-info">
                        <h3>@user.DisplayName</h3>
                        <p class="bio">
                            @(string.IsNullOrWhiteSpace(user.Bio) ? "No bio available." : user.Bio)
                        </p>
                    </div>

                    <div class="stats">
                        <div>
                            <span class="stat-value">@user.Reputation</span>
                            <span class="stat-label">Reputation</span>
                        </div>
                        <div>
                            <span class="stat-value">@user.TotalQuestions</span>
                            <span class="stat-label">Questions</span>
                        </div>
                        <div>
                            <span class="stat-value">@user.TotalSolutions</span>
                            <span class="stat-label">Solutions</span>
                        </div>
                    </div>

                    <div class="footer">
                        <span class="joined">
                            Joined @user.JoinedAt.ToShortDateString()
                        </span>

                        @if (user.IsBanned)
                        {
                            <span class="badge banned">Banned</span>
                        }
                        else if (!user.IsActive)
                        {
                            <span class="badge inactive">Inactive</span>
                        }
                        else
                        {
                            <span class="badge active">Active</span>
                        }
                    </div>

                </div>
            }
            
        }
    </div>
}

@code {
    private List<User> Users = [];

    protected override async Task OnInitializedAsync()
    {
        await HandleGetAllUsers();
    }

    public async Task HandleGetAllUsers()
    {
        Users = await authService.GetListOfUsers();
    }
}