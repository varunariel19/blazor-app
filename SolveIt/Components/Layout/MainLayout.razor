    @inherits LayoutComponentBase
    @implements IDisposable

    @using System.Security.Claims
    @using SolveIt.Services
    @using SolveIt.Models
    @using SolveIt.Components.Modules
    @using Microsoft.AspNetCore.Identity
    @using Microsoft.AspNetCore.Components.Authorization


    @inject SolveIt.Services.QuestionService questionService
    @inject AuthenticationStateProvider AuthProvider
    @inject UserManager<User> UserManager
    @inject SolveIt.UI_state.UiStateService UiState
    @inject NavigationManager NavManager
    @inject SolveIt.Services.AuthService authService

<div class="app-wrapper">

    <nav class="navbar">
        <div class="navbar-brand">
            <span class="brand-icon">⬡</span>
            <span class="brand-name">Solve<span class="brand-accent">It</span></span>
        </div>

        @* In the navbar search area *@
        <div class="navbar-search">
            <div class="search-container">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.35-4.35" />
                </svg>
                <input type="text"
                placeholder="Search questions, tags, users..."
                @bind="searchedValue"
                @bind:event="oninput"
                @onkeydown="HandleKeyDown"
                class="search-input" />
                <button @onclick="HandleSearchQuestion" class="search-kbd">Search</button>

                @if (showDropdown)
                {
                    <div class="search-dropdown">
                        @if (isSearching)
                        {
                            <div class="dropdown-no-results">Searching...</div>
                        }
                        else if (searchResults.Count == 0)
                        {
                            <div class="dropdown-no-results">No results found for "@searchedValue"</div>
                        }
                        else
                        {
                            <div class="dropdown-header">Results for "@searchedValue"</div>

                            @foreach (var q in searchResults.Take(takeLimit))
                            {
                                <a class="search-result-item" href="/question/@q.QuestionId">
                                    <img class="result-avatar"
                                    src="@(string.IsNullOrEmpty(q.User.AvatarUrl)
                                         ? $"https://api.dicebear.com/7.x/shapes/svg?seed={q.User.DisplayName}"
                                         : q.User.AvatarUrl)"
                                    alt="@q.User.DisplayName" />
                                    <div class="result-body">
                                        <div class="result-title">@q.Title</div>
                                        <div class="result-meta">
                                            <span class="result-author">@q.User.DisplayName</span>
                                            @foreach (var tag in q.QuestionTags.Take(3))
                                            {
                                                <span class="result-tag-pill">@tag.TagName</span>
                                            }
                                            <div class="result-stats">
                                                <span class="result-stat">
                                                    ▲ @q.VoteCount
                                                </span>
                                                <span class="result-stat @(q.SolutionCount > 0 ? "has-answers" : "")">
                                                    ✓ @q.SolutionCount
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            }

                            @if (searchResults.Count > 3)
                            {

                                <div class="dropdown-footer" @onclick="HandleViewAll">
                                    @GetFooterText()
                                </div>
                            }

                        }
                    </div>
                }
            </div>
        </div>


        <div class="navbar-actions">
            <button class="nav-btn ask-btn" @onclick="UiState.ToggleAskForm">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M12 5v14M5 12h14" />
                </svg>
                Ask Question
            </button>

            <button class="nav-icon-btn" title="Notifications">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                </svg>
                <span class="notif-badge">3</span>
            </button>

            <button class="nav-icon-btn" title="Inbox">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                </svg>
            </button>

            @if (UiState.IsLoggedIn)
            {
                <UserMenu />
            }
            else
            {
                <a href="/login">Sign in</a>
            }
        </div>
    </nav>

    <div class="content-wrapper">
        <aside class="sidebar">
            <div class="sidebar-section">
                <p class="sidebar-label">NAVIGATE</p>
                <nav class="sidebar-nav">
                    <NavLink href="/" class="sidebar-link" ActiveClass="active-none">

                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                            <polyline points="9 22 9 12 15 12 15 22" />
                        </svg>
                        Home
                    </NavLink>
                    <NavLink href="/questions" class="sidebar-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
                            <path d="M12 17h.01" />
                        </svg>
                        Questions
                        <span class="sidebar-count">1.2k</span>
                    </NavLink>
                    <NavLink href="/tags" class="sidebar-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
                            <line x1="7" y1="7" x2="7.01" y2="7" />
                        </svg>
                        Tags
                    </NavLink>
                    <NavLink href="/users" class="sidebar-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                        Users
                    </NavLink>
                </nav>
            </div>

            <div class="sidebar-section">
                <p class="sidebar-label">MY STUFF</p>
                <nav class="sidebar-nav">
                    <a href="/profile" class="sidebar-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                        Profile
                    </a>
                    <a href="/saved" class="sidebar-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z" />
                        </svg>
                        Saved
                        <span class="sidebar-count">7</span>
                    </a>
                </nav>
            </div>

            <div class="sidebar-section">
                <p class="sidebar-label">TOP TAGS</p>
                <div class="tag-list">
                    @foreach (var tag in allTags)
                    {
                        <span @onclick='() => FetchQuestionsAccTag(tag.TagName)' class="tag">@tag.TagName</span>
                    }
                </div>
            </div>
        </aside>

        <main class="main-content">
            @Body
        </main>

        <aside class="right-panel">
            <div class="widget">
                <h4 class="widget-title">🔥 Hot Today</h4>
                <ul class="hot-list">
                    @foreach( var hotQ in hotQuesRes.Take(5))
                    {
                        <li><a href="/question/@hotQ.QuestionId">@hotQ.Title</a></li>

                    }

                </ul>
            </div>

            <div class="widget">
                <h4 class="widget-title">🏆 Top Contributors</h4>
                <div class="contributor-list">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var idx = i;
                        <div class="contributor">
                            <img src="@($"https://api.dicebear.com/7.x/shapes/svg?seed=user{idx * 7}")" alt="user" />
                            <div>
                                <p class="contributor-name">dev_user_@idx</p>
                                <p class="contributor-rep">@(5280 - idx * 320) rep</p>
                            </div>
                            <span class="rank-badge">#@idx</span>
                        </div>
                    }
                </div>
            </div>
        </aside>
    </div>
</div>



@code {


    private List<Tag> allTags = [];
    public string searchedValue = string.Empty;

    private List<Question> searchResults = [];
    private List<Question> hotQuesRes = [];
    private int takeLimit = 3;
    private bool viewResult = false;
    private bool showDropdown = false;
    private bool isSearching = false;
    private CancellationTokenSource? _debounceToken;
    private User? UserData = null;


    protected override async Task OnInitializedAsync()
    {
        UiState.OnChange += StateHasChanged;
        await LoadUserIntoState();
        await LoadHotQuestions();
    }

    public void Dispose()
    {
        UiState.OnChange -= StateHasChanged;
        _debounceToken?.Cancel();
    }



    private async Task LoadUserIntoState()
    {
        if (UiState.IsLoggedIn) return;

        var user = await authService.GetCurrentUserAsync();
        if (user != null)
            UiState.HandleUserLogin(user); 

    }

    private async void HandleChange()
    {
        await InvokeAsync(StateHasChanged);
    }


    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            showDropdown = false;
            return;
        }

        if (e.Key == "Enter")
        {
            await HandleSearchQuestion();
            return;
        }

        _debounceToken?.Cancel();
        _debounceToken = new CancellationTokenSource();
        var token = _debounceToken.Token;

        try
        {
            await Task.Delay(350, token);

            if (!string.IsNullOrWhiteSpace(searchedValue) && searchedValue.Length >= 2)
            {
                isSearching = true;
                showDropdown = true;
                await InvokeAsync(StateHasChanged);

                var results = await questionService.SearchQuestionAsync(searchedValue);
                searchResults = results; 
                isSearching = false;
            }
            else
            {
                showDropdown = false;
                searchResults.Clear();
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {

        }
    }

    public async Task HandleSearchQuestion()
    {
        if (!string.IsNullOrEmpty(searchedValue))
        {
            isSearching = true;
            showDropdown = true;
            StateHasChanged();

            var questions = await questionService.SearchQuestionAsync(searchedValue);
            searchResults = questions;
            isSearching = false;
            // UiState.SetQuestions(questions);
            StateHasChanged();
        }
    }

    private void HandleViewAll()
    {
        if(viewResult)
        {
            takeLimit = 3;
            viewResult = false;

        }else
        {
            takeLimit = searchResults.Count;
            viewResult = true;
        }
    }

    public async Task FetchQuestionsAccTag(string selectedTag)
    {
        var questions = await questionService.GetQuestionsByTag(selectedTag);
        UiState.SetQuestions(questions.Questions);
    }


    public async Task LoadHotQuestions()
    {
        var hotQuestions = await questionService.GetHotQuestionAsync();
        if(hotQuestions != null)
        {
            hotQuesRes = hotQuestions;
        }
    }

        private string GetFooterText()
        {
            return viewResult
                ? "Hide results"
                : $"View all {searchResults.Count} results →";
        }



    }




