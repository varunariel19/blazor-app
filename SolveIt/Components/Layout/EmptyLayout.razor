@inherits LayoutComponentBase
@using System.Security.Claims
@using SolveIt.Services
@using SolveIt.Models
@using SolveIt.Components.Modules
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization

@inject SolveIt.Services.QuestionService questionService

@inject AuthenticationStateProvider AuthProvider
@inject UserManager<User> UserManager
@inject SolveIt.UI_state.UiStateService UiState

<div class="auth-layout-wrapper">
    @Body
</div>

<style>
    .auth-layout-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        width: 100vw;
        background-color: #0f1113; 
        margin: 0;
        padding: 20px;
        box-sizing: border-box;

    }


    body {
        background: #0f0f0f;
        color: #e5e5e5;
        font-family: Arial, sans-serif;
    }

    .account-container {
        max-width: 900px;
        margin: auto;
        padding: 20px;
    }

    /* HEADER */
    .profile-header {
        margin-bottom: 40px;
    }

    .avatar-circle {
        width: 90px;
        height: 90px;
        background: #1e293b;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: auto;
        font-size: 28px;
        font-weight: bold;
    }

    .email {
        color: #9ca3af;
    }

    .badges {
        margin: 10px 0;
    }

    .badge {
        padding: 5px 10px;
        border-radius: 12px;
        font-size: 12px;
        margin: 0 5px;
    }

        .badge.active {
            background: #065f46;
            color: #10b981;
        }

        .badge.rep {
            background: #1e3a8a;
            color: #60a5fa;
        }

    .stats {
        display: flex;
        justify-content: space-around;
        margin-top: 20px;
    }

        .stats h3 {
            margin: 0;
        }

    /* FORM */
    section {
        margin-bottom: 40px;
    }

    h4 {
        margin-bottom: 10px;
    }

    .input, textarea, input {
        width: 100%;
        padding: 10px;
        margin: 6px 0 12px;
        border-radius: 6px;
        border: 1px solid #333;
        background: #111;
        color: #fff;
    }

    textarea {
        min-height: 80px;
    }

    .input-group {
        display: flex;
        gap: 10px;
        align-items: center;
    }

        .input-group span {
            background: #222;
            padding: 10px;
            border-radius: 6px;
        }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    /* BUTTONS */
    .btn-primary {
        background: #2563eb;
        border: none;
        padding: 10px 16px;
        color: white;
        border-radius: 6px;
    }

    .btn-secondary {
        background: #333;
        border: none;
        padding: 10px 16px;
        color: white;
        border-radius: 6px;
    }

    .btn-danger {
        background: #7f1d1d;
        padding: 10px 16px;
        border: none;
        color: #f87171;
        border-radius: 6px;
    }

    /* INFO GRID */
    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
    }

    /* DANGER */
    .danger {
        border: 1px solid #7f1d1d;
        padding: 20px;
        border-radius: 10px;
    }
</style>