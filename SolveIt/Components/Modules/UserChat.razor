    }

        .uc-empty p {
            margin: 0;
            font-size: 13px;
        }

    .uc-row {
        display: flex;
        align-items: flex-end;
        gap: 8px;
    }

    .uc-row--mine {
        flex-direction: row-reverse;
    }

    .uc-row--theirs {
        flex-direction: row;
    }

    .uc-avatar-wrap {
        flex-shrink: 0;
    }

    .uc-avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        object-fit: cover;
        display: block;
    }

    .uc-avatar--fallback {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0074cc;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
    }

    .uc-bubble-col {
        display: flex;
        flex-direction: column;
        gap: 3px;
        max-width: 72%;
        align-items: flex-start;
    }

    .uc-bubble-col--mine {
        align-items: flex-end;
    }

    .uc-sender-name {
        font-size: 11px;
        font-weight: 600;
        color: #6a737c;
        padding-left: 4px;
    }

    .uc-bubble {
        padding: 8px 12px;
        border-radius: 16px;
        font-size: 13px;
        line-height: 1.45;
        word-break: break-word;
        white-space: pre-wrap;
    }

    .uc-bubble--theirs {
        background: #f0f2f5;
        color: #232629;
        border-bottom-left-radius: 4px;
    }

    .uc-bubble--mine {
        background: #0074cc;
        color: #fff;
        border-bottom-right-radius: 4px;
    }

    .uc-time {
        font-size: 10px;
        color: #9fa6ad;
        padding: 0 4px;
    }

    .uc-time--mine {
        text-align: right;
    }

    .uc-status {
        margin-left: 3px;
        color: #90c8f0;
        font-size: 11px;
    }

    .uc-input-bar {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        padding: 8px 10px;
        border-top: 1px solid #e3e6e8;
        background: #fafafa;
    }

    .uc-textarea {
        flex: 1;
        resize: none;
        border: 1px solid #d6d9dc;
        border-radius: 18px;
        padding: 8px 14px;
        font-size: 13px;
        font-family: inherit;
        line-height: 1.4;
        color: #232629;
        background: #fff;
        outline: none;
        max-height: 100px;
        overflow-y: auto;
        transition: border-color .15s;
    }

        .uc-textarea:focus {
            border-color: #0074cc;
        }

        .uc-textarea::placeholder {
            color: #9fa6ad;
        }

    .uc-send-btn {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        border: none;
        border-radius: 50%;
        background: #0074cc;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .15s, transform .1s;
    }

        .uc-send-btn:hover:not(:disabled) {
            background: #0063b1;
            transform: scale(1.05);
        }

        .uc-send-btn:disabled {
            background: #c8d0d8;
            cursor: not-allowed;
        }


</style>



