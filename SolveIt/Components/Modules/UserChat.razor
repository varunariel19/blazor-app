@using SolveIt.Services
@inject NavigationManager NavManager
@inject SolveIt.UI_state.UiStateService UiState
@inject SolveIt.Services.ConversationService ConversationService
@inject SolveIt.UI_state.SignalRService SignalR
@inject IJSRuntime JS


<div class="uc-root">

    <div class="uc-messages" @ref="_scrollRef">
        @if (Conversations.Count == 0)
        {
            <div class="uc-empty">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
                </svg>
                <p>No messages yet. Say hello!</p>
            </div>
        }
        else
        {
            @foreach (var msg in Conversations)
            {
                bool isMine = msg.SenderId == _currentUserId;
                <div class="uc-row @(isMine ? "uc-row--mine" : "uc-row--theirs")">
                    @if (!isMine)
                    {
                        <div class="uc-avatar-wrap">
                            @if (!string.IsNullOrWhiteSpace(msg.Sender.AvatarUrl))
                            {
                                <img class="uc-avatar" src="@msg.Sender.AvatarUrl" alt="@msg.Sender.DisplayName" />
                            }
                            else
                            {
                                <div class="uc-avatar uc-avatar--fallback">
                                    @(msg.Sender.DisplayName?.Substring(0, 1).ToUpper() ?? "?")
                                </div>
                            }
                        </div>
                    }
                    <div class="uc-bubble-col @(isMine ? "uc-bubble-col--mine" : "")">
                        @if (!isMine)
                        {
                            <span class="uc-sender-name">@msg.Sender.DisplayName</span>
                        }
                        <div class="uc-bubble @(isMine ? "uc-bubble--mine" : "uc-bubble--theirs")">
                            @msg.Content
                        </div>
                        <span class="uc-time @(isMine ? "uc-time--mine" : "")">
                            @FormatTime(msg.SendedAt)
                            @if (isMine)
                            {
                                <span class="uc-status">
                                    @if (msg.Seen)
                                    {
                                        <span title="Read">✓✓</span>
                                    }
                                    else
                                    {
                                        <span title="Sent">✓</span>
                                    }
                                </span>
                            }
                        </span>
                    </div>
                </div>
            }
        }
    </div>

    <div class="uc-input-bar">
        <textarea class="uc-textarea"
        placeholder="Type a message…"
        rows="1"
        @bind="_draft"
        @bind:event="oninput"
        @onkeydown="HandleKeyDown" />
        <button class="uc-send-btn"
        disabled="@(string.IsNullOrWhiteSpace(_draft))"
        @onclick="SendMessage"
        title="Send">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
                <line x1="22" y1="2" x2="11" y2="13" />
                <polygon points="22 2 15 22 11 13 2 9 22 2" />
            </svg>
        </button>
    </div>

</div>



<style>

    .uc-root {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    .uc-messages {
    flex: 1;
    overflow-y: auto;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scroll-behavior: smooth;
    }

    .uc-empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #9fa6ad;
    gap: 8px;
    padding: 24px;
    }

    .uc-empty p {
    margin: 0;
    font-size: 13px;
    }

    .uc-row {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    }

    .uc-row--mine {
    flex-direction: row-reverse;
    }

    .uc-row--theirs {
    flex-direction: row;
    }

    .uc-avatar-wrap {
    flex-shrink: 0;
    }

    .uc-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    }

    .uc-avatar--fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0074cc;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    }

    .uc-bubble-col {
    display: flex;
    flex-direction: column;
    gap: 3px;
    max-width: 72%;
    align-items: flex-start;
    }

    .uc-bubble-col--mine {
    align-items: flex-end;
    }

    .uc-sender-name {
    font-size: 11px;
    font-weight: 600;
    color: #6a737c;
    padding-left: 4px;
    }

    .uc-bubble {
    padding: 8px 12px;
    border-radius: 16px;
    font-size: 13px;
    line-height: 1.45;
    word-break: break-word;
    white-space: pre-wrap;
    }

    .uc-bubble--theirs {
    background: #f0f2f5;
    color: #232629;
    border-bottom-left-radius: 4px;
    }

    .uc-bubble--mine {
    background: #0074cc;
    color: #fff;
    border-bottom-right-radius: 4px;
    }

    .uc-time {
    font-size: 10px;
    color: #9fa6ad;
    padding: 0 4px;
    }

    .uc-time--mine {
    text-align: right;
    }

    .uc-status {
    margin-left: 3px;
    color: #90c8f0;
    font-size: 11px;
    }

    .uc-input-bar {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    padding: 8px 10px;
    border-top: 1px solid #e3e6e8;
    background: #fafafa;
    }

    .uc-textarea {
    flex: 1;
    resize: none;
    border: 1px solid #d6d9dc;
    border-radius: 18px;
    padding: 8px 14px;
    font-size: 13px;
    font-family: inherit;
    line-height: 1.4;
    color: #232629;
    background: #fff;
    outline: none;
    max-height: 100px;
    overflow-y: auto;
    transition: border-color .15s;
    }

    .uc-textarea:focus {
    border-color: #0074cc;
    }

    .uc-textarea::placeholder {
    color: #9fa6ad;
    }

    .uc-send-btn {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 50%;
    background: #0074cc;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background .15s, transform .1s;
    }

    .uc-send-btn:hover:not(:disabled) {
    background: #0063b1;
    transform: scale(1.05);
    }

    .uc-send-btn:disabled {
    background: #c8d0d8;
    cursor: not-allowed;
    }


</style>



@code {
    [Parameter] public Guid InboxId { get; set; } = Guid.Empty;
    [Parameter] public string ReceiverId { get; set; } = string.Empty;
    [Parameter] public List<ConversationService.ConversationDto> Conversations { get; set; } = [];

    private string _currentUserId = string.Empty;
    private string _draft = string.Empty;
    private ElementReference _scrollRef;


    private string _userQuery = string.Empty;
    private bool _showDropdown = false;
    private User? _selectedUser = null;
    private List<User> _searchResults = [];

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        // await JS.InvokeVoidAsync("scrollToBottom", _scrollRef);
        return Task.CompletedTask;
    }

    protected override async Task OnInitializedAsync()
    {

        _currentUserId = UiState.UserData!.Id;

        await base.OnInitializedAsync();
    }


    private void ClearUser()
    {
        _selectedUser = null;
        Conversations.Clear();
    }

    protected override void OnInitialized()
    {

        // get all the message of that user where I am the receiver . 

    }

    private async Task SendMessage()
    {
        var text = _draft.Trim();
        if (string.IsNullOrWhiteSpace(text)) return;

        var message = new ConversationService.ConversationDto(
            ConversationId: Guid.NewGuid(),
            InboxId:InboxId,
            SenderId: _currentUserId,
            ReceiverId: ReceiverId,
            Content: text,
            SendedAt: DateTime.Now,
            Seen: false,
            Sender: new InboxDilog.UserSummaryDto(
                AvatarUrl: UiState.UserData!.AvatarUrl ?? string.Empty,
                DisplayName: UiState.UserData!.DisplayName ?? string.Empty
            ),
            Receiver: new InboxDilog.UserSummaryDto(
                AvatarUrl:  string.Empty,
                DisplayName:  string.Empty
            )
        );

        Conversations.Add(message);
        _draft = string.Empty;

        await ConversationService.SendMessageAsync(message);
    }


    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private string FormatTime(DateTime dt)
    {
        var diff = DateTime.Now - dt;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return dt.ToString("h:mm tt");
        return dt.ToString("MMM d, h:mm tt");
    }


}
