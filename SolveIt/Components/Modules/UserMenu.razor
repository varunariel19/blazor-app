@using SolveIt.Services
@inject NavigationManager NavManager

@if (UserState?.IsAuthenticated == true)
{
    @if (_open)
    {
        <div @onclick="ToggleMenu" style="position:fixed;inset:0;z-index:99;"></div>
    }

    <div style="position:relative;display:inline-block;">
        <button @onclick="ToggleMenu" style="display:flex;align-items:center;gap:8px;background:#18181b;border:0.5px solid #2a2a2e;border-radius:999px;padding:5px 12px 5px 5px;cursor:pointer;">
            <img src="@UserState.CurrentUser!.AvatarUrl" style="width:32px;height:32px;border-radius:50%;background:#2a2a2e;" />
            <span style="font-size:13px;color:#ccc;">@UserState.CurrentUser!.DisplayName</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9" /></svg>
        </button>

        @if (_open)
        {
            <div style="position:absolute;right:0;margin-top:8px;background:#18181b;border:0.5px solid #2a2a2e;border-radius:12px;width:220px;overflow:hidden;z-index:100;">
                <div style="padding:12px 14px;border-bottom:0.5px solid #2a2a2e;">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <img src="@UserState.CurrentUser!.AvatarUrl" style="width:38px;height:38px;border-radius:50%;background:#2a2a2e;" />
                        <div>
                            <p style="font-size:13px;font-weight:500;color:#f0eeff;margin:0;">@UserState.CurrentUser!.DisplayName</p>
                            <p style="font-size:12px;color:#666;margin:0;">@UserState.CurrentUser!.Email</p>
                        </div>
                    </div>
                </div>

                <div style="padding:6px;">
                    <a href="/account" style="display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;text-decoration:none;color:#ccc;font-size:13px;">Account details</a>
                    <a href="/settings" style="display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;text-decoration:none;color:#ccc;font-size:13px;">Settings</a>
                    <a href="/my-questions" style="display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;text-decoration:none;color:#ccc;font-size:13px;">My questions</a>
                    <a href="/saved" style="display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;text-decoration:none;color:#ccc;font-size:13px;">Saved answers</a>
                </div>

                <div style="padding:6px;border-top:0.5px solid #2a2a2e;">
                    <button @onclick="Logout" style="display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;background:transparent;border:none;color:#f87171;font-size:13px;cursor:pointer;width:100%;">
                        Sign out
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    [CascadingParameter] UserStateService? UserState { get; set; }
    private bool _open = false;

    private void ToggleMenu() => _open = !_open;

    private void Logout()
    {
        UserState?.Clear();
        NavManager.NavigateTo("/Account/Logout", forceLoad: true);
    }
}